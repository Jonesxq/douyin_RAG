APP_NAME=Douyin Favorites RAG
APP_ENV=dev
API_PREFIX=
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=sqlite:///./backend/storage/douyin_rag.db

STORAGE_ROOT=backend/storage
PLAYWRIGHT_USER_DATA_DIR=backend/storage/playwright
PLAYWRIGHT_BROWSERS_PATH=backend/storage/playwright-browsers
PLAYWRIGHT_BROWSER_CHANNEL=
DOUYIN_HOME_URL=https://www.douyin.com/
FAVORITES_URL=https://www.douyin.com/user/self?showTab=favorite_collection
PLAYWRIGHT_HEADLESS=false

TASK_WORKER_CONCURRENCY=2
TASK_RETRY_COUNT=2

ASR_MODEL_SIZE=small
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
FFMPEG_PATH=

CHROMA_PERSIST_DIRECTORY=backend/storage/chroma
CHROMA_COLLECTION_NAME=video_chunks_local
CHROMA_DISTANCE=cosine

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_MAX_RETRIES=0
QWEN_ROUTE_TIMEOUT_SEC=4
QWEN_ROUTE_MAX_TOKENS=1
QWEN_CHAT_TIMEOUT_SEC=20
QWEN_STREAM_TIMEOUT_SEC=20
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_CACHE_DIR=backend/storage/models

RAG_TOPK_DENSE=20
RAG_TOPK_FTS=20
RAG_CONTEXT_COUNT=8
RAG_DB_CONTENT_LIMIT=12
RAG_EXCERPT_CHARS=800
RAG_PROMPT_MAX_CONTEXT_CHARS=4500
RAG_ROUTE_WITH_LLM=false
CHAT_HISTORY_WINDOW=6
CHAT_MAX_CONTENT_CHARS=800

STARTUP_VALIDATE=true
STARTUP_REQUIRE_PYTHON312=true
